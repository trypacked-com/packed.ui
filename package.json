    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.15",
    "storybook": "^8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
