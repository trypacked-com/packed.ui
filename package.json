{
  "name": "packed.ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bun run build:registry && next build",
    "build:registry": "bun run scripts/merge-registry-items.ts && bun run scripts/build-registry.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "bun run scripts/build-storybook.ts",
    "test": "bun test",
    "test:visual": "playwright test",
    "test:visual:update": "bunx playwright test --update-snapshots",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/lora": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.20.0",
    "next": "15.5.19",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.79.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
